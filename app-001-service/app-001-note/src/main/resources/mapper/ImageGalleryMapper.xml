<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="icu.huajuan.mapper.ImageGalleryMapper">


    <select id="selectOneImageUrlByNoteId" resultType="icu.huajuan.model.note.vo.Cover">
        select id, image_url
        from image_gallery
        where note_id = #{id} limit 1
    </select>
</mapper>