<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="icu.huajuan.mapper.QiNiuMapper">

    <select id="getImage" resultType="icu.huajuan.model.file.vo.ImageVo">
        select id, image_url
        from image_gallery
        where note_id in
        <foreach collection="noteIds" item="noteId" open="(" separator="," close=")">
            #{noteId}
        </foreach>
    </select>
</mapper>